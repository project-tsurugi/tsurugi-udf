#include "{{ proto_base_name }}.pb.h"

#ifdef DEBUG_RPC_CLIENT
#include <iostream>
#define RPC_LOG(x) do { std::cerr << x << std::endl; } while(0)
#else
#define RPC_LOG(x)
#endif

#include <iostream>
